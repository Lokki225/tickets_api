-- Insert messages between users
INSERT INTO `message` (`expediteurId`, `destinataireId`, `contenu`) VALUES
(1, 5, 'Hey! Are you attending the music festival?'),
(5, 1, 'Yes! I got VIP tickets. Want to meet up?'),
(1, 5, 'That would be awesome! I have general admission.'),
(2, 6, 'The conference venue looks great this year.'),
(6, 2, 'I agree! The speaker lineup is impressive.'),
(7, 8, 'Want to go to the basketball game together?'),
(8, 7, 'Sure! I can get us good seats.'),
(3, 4, 'Please scan the tickets at entrance A.'),
(4, 3, 'Will do. How many people are expected?'),
(3, 4, 'Around 5000 for the music festival.'),
(9, 10, 'The gala dinner planning is going well.'),
(10, 9, 'Excellent! Let me know if you need help.'),
(1, 7, 'Thanks for recommending the art exhibition!'),
(7, 1, 'You''re welcome! It was amazing.'),
(8, 10, 'Are you speaking at the marketing workshop?'),
(10, 8, 'Yes! I''m presenting on social media strategies.');

